{
  "manifest_version": 3,
  "name": "GPT Helper Conversation TOC",
  "description": "Adds a right-side in-page navigation for ChatGPT conversation turns.",
  "version": "0.1.0",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
